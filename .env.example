# ============================================================================
# LMS Frontend — Biến môi trường
# Copy file này thành .env và điền giá trị thật từ Supabase Dashboard
# ============================================================================

# URL dự án Supabase (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon (Public) Key — An toàn để dùng ở frontend
# (Settings → API → anon public key)
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key
