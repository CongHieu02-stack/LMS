# ============================================================================
# LMS Backend — Biến môi trường
# Copy file này thành .env và điền giá trị thật từ Supabase Dashboard
# ============================================================================

# URL dự án Supabase (Settings → API → Project URL)
SUPABASE_URL=https://your-project-id.supabase.co

# Service Role Key — KHÔNG BAO GIỜ để lộ ra frontend
# (Settings → API → service_role key)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Port cho Express server
PORT=3000
